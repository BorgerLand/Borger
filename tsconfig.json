{
	"compilerOptions": {
		"target": "ESNext",
		"lib": ["ESNext", "DOM", "DOM.Iterable"],
		"module": "ESNext",
		"skipLibCheck": true,
		"baseUrl": ".",
		"paths": {
			"@borger/code_generator/*": ["engine/code_generator/src/*"],

			//should match vite.config.ts
			"@borger/rs": ["engine/client/rs/pkg"],
			"@borger/ts": ["engine/client/ts/src"],
			"@borger/ts/*": ["engine/client/ts/src/*"],
			"@game/*": ["game/*"]
		},
		"moduleResolution": "bundler",
		"resolveJsonModule": true,
		"isolatedModules": true,
		"noEmit": true,
		"strict": true,
		"allowImportingTsExtensions": true,
		"jsx": "react-jsx"
	}
}
